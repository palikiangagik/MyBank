@{
	ViewData["Title"] = "My Bank - Open new account";
}

@model OpenNewAccountViewModel

<h3>Open new account</h3>

<form asp-antiforgery="true">
	<div class="validation" asp-validation-summary="All"></div>
	<label asp-for="Amount"></label><br/>
	<input asp-for="Amount"/><br/>
	<br/>
	<input type="submit" class="button" value="Open new account"/>
</form>